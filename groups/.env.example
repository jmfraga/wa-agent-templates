# Phoenix v2 — env vars (copia a .env y completa)

# === Brain ===
ANTHROPIC_API_KEY=
PHOENIX_BRAIN_MODEL_DEFAULT=claude-haiku-4-5-20251001
PHOENIX_BRAIN_MODEL_SAFETY=claude-sonnet-4-6
# Dev: SQLite local. Prod RPi5: postgresql+psycopg://phoenix:phoenix@localhost:5432/phoenix
PHOENIX_BRAIN_DB_URL=sqlite:///./phoenix.db
PHOENIX_BRAIN_PORT=8102
# WA JID del owner (<OWNER>) — formato 5214426...@s.whatsapp.net (se completa tras pair)
PHOENIX_OWNER_JID=
# URL del listener para outbound (mensajes que el brain dispara, ej. discussion starters)
PHOENIX_LISTENER_URL=http://localhost:8100
PHOENIX_HISTORY_WINDOW=30
PHOENIX_LOG_LEVEL=info

# === wa-listener ===
BRAIN_URL=http://localhost:8102
AUTH_DIR=./auth/listener
LISTENER_PORT=8100
LOG_LEVEL=info
# JID del owner — mismo que PHOENIX_OWNER_JID
OWNER_JID=
# 1 = también imprime QR en terminal (debug). 0 = sólo /wa/qr-stream a la UI.
PHOENIX_QR_TERMINAL=0

# === UI admin ===
PHOENIX_UI_PORT=8101
