[Unit]
Description=Iris v2 Brain (FastAPI :8096)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=iris
WorkingDirectory=/opt/iris/brain
EnvironmentFile=/opt/iris/brain/.env
ExecStart=/opt/iris/brain/.venv/bin/uvicorn iris_brain.server:app --host 0.0.0.0 --port 8096
Restart=on-failure
RestartSec=5
StandardOutput=append:/var/log/iris-brain.log
StandardError=append:/var/log/iris-brain.log

[Install]
WantedBy=multi-user.target
