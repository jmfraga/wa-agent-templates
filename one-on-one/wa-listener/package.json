{
  "name": "iris-wa-listener",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Iris v2 WhatsApp listener (Baileys) + relay-bot bridge to Owner",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:relay": "tsx watch src/relay-bot.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:relay": "node dist/relay-bot.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc11",
    "dotenv": "^16.4.5",
    "form-data": "^4.0.5",
    "node-fetch": "^3.3.2",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "optionalDependencies": {
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
