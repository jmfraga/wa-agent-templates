# brain — env vars for iris-brain (FastAPI :8096)

ANTHROPIC_API_KEY=sk-ant-...                                    # required
IRIS_BRAIN_MODEL_DEFAULT=claude-haiku-4-5-20251001              # default model
IRIS_BRAIN_MODEL_SAFETY=claude-sonnet-4-6                       # safety paths (crisis detector, ambiguous escalation)
IRIS_BRAIN_DB_URL=postgresql+psycopg://iris:iris@localhost:5432/iris
IRIS_BRAIN_PORT=8096
IRIS_BRAIN_SOUL_PATH=SOUL.md                                    # path to your SOUL.md (relative to brain/)
JMF_RELAY_WEBHOOK=http://localhost:8098/send-to-jmf             # relay-bot webhook
