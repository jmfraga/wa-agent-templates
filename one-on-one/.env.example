# one-on-one — top-level env (copia a .env y completa)
# Cada subproyecto tiene su propio .env.example con variables específicas.

# === Brain (FastAPI :8096) ===
ANTHROPIC_API_KEY=sk-ant-...                                    # required — console.anthropic.com
IRIS_BRAIN_MODEL_DEFAULT=claude-haiku-4-5-20251001
IRIS_BRAIN_MODEL_SAFETY=claude-sonnet-4-6
IRIS_BRAIN_DB_URL=postgresql+psycopg://iris:iris@localhost:5432/iris
IRIS_BRAIN_PORT=8096
IRIS_BRAIN_SOUL_PATH=SOUL.md
# Webhook to which brain pushes ticket notifications (relay-bot)
OWNER_RELAY_WEBHOOK=http://localhost:8098/send-to-owner

# === wa-listener (Node + Baileys :8099) ===
BRAIN_URL=http://localhost:8096
AUTH_DIR=./auth/listener
LOG_LEVEL=info

# === relay-bot (Python + Telegram :8098) ===
RELAY_CHANNEL=telegram
RELAY_BOT_PORT=8098
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# Owner's Telegram numeric user ID (find with @userinfobot)
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# === UI (FastAPI + HTMX :8097) ===
IRIS_UI_PORT=8097
BRAIN_TIMEOUT_SECONDS=10
